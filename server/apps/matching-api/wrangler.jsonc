{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "matching-api",
  "main": "src/index.ts",
  "compatibility_date": "2024-09-23",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "realtime-p2p-db",
      "database_id": "<YOUR_D1_DATABASE_ID>"
    }
  ],
  "vars": {
    // Host only, no scheme. Fill in after `pnpm deploy:party` (see server/README section).
    "PARTYKIT_HOST": "signaling-party.<your-partykit-user>.partykit.dev"
  }
}

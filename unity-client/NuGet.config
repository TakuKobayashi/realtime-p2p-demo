<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="NuGet" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <config>
    <!-- NuGetForUnity installs packages here; the RealtimeP2PKit asmdef references
         MessagePack.dll / MessagePack.Annotations.dll from this folder by filename. -->
    <add key="repositoryPath" value="./Assets/Packages" />
  </config>
</configuration>
